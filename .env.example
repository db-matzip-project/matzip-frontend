# 프로덕션 빌드 시 API URL
VITE_API_BASE_URL=https://unthread-book-salvation.ngrok-free.dev

# 로컬 개발: Vite가 /api 요청을 이 주소로 프록시 (Swagger Referer 이슈 우회)
VITE_API_PROXY_TARGET=https://unthread-book-salvation.ngrok-free.dev

# 카카오 개발자 콘솔 > 앱 > 플랫폼 키 > JavaScript 키
VITE_KAKAO_MAP_APP_KEY=your_javascript_key_here
