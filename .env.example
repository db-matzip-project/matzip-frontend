# ============================================================
# matzip-FRONTEND 전용 (.env / .env.local)
# 이 파일은 matzip-frontend 루트에만 둡니다.
# 백엔드(Spring) 폴더에 복사해도 Spring은 읽지 않습니다.
# ============================================================
#
# VITE_ 접두사 = Vite/React 빌드·개발 서버만 사용
# Spring은 VITE_* 변수를 사용하지 않습니다.
#
# 설정 후: npm run dev (재시작 필수)

# 백엔드 API 주소 (로컬 Spring Boot 기본 8080)
VITE_API_BASE_URL=http://localhost:8080
VITE_API_PROXY_TARGET=http://localhost:8080

# 원격/ngrok 테스트 시 위 두 줄만 백엔드 주소로 변경

# 카카오맵 화면용 — JavaScript 키 (플랫폼 키 > JavaScript)
# REST API 키(KAKAO_REST_API_KEY)와 다릅니다 → 백엔드 전용
VITE_KAKAO_MAP_APP_KEY=your_javascript_key_here

# 카카오 장소 키워드 검색 (로컬 API, REST API 키 — 일정 from-place용)
VITE_KAKAO_REST_API_KEY=your_rest_api_key_here

# ------------------------------------------------------------
# 아래는 백엔드 application.yml / 백엔드 .env 에 넣는 값입니다.
# 프론트 .env 에 넣지 마세요.
# ------------------------------------------------------------
# JWT_SECRET=...
# KAKAO_REST_API_KEY=...
