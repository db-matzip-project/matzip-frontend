# === 프론트엔드 (Vite) ===
# 로컬: 백엔드 Spring Boot 기본 포트
VITE_API_BASE_URL=http://localhost:8080
VITE_API_PROXY_TARGET=http://localhost:8080

# 원격/ngrok 테스트 시 위 두 값만 현재 백엔드 주소로 교체
# 예: VITE_API_PROXY_TARGET=https://xxxx.ngrok-free.dev

# 카카오맵 JavaScript 키 (개발자 콘솔 > 플랫폼 키)
# 지도 화면 전용. REST API 키와 다릅니다.
VITE_KAKAO_MAP_APP_KEY=your_javascript_key_here

# === 백엔드 전용 (프론트 .env에 넣지 마세요) ===
# KAKAO_REST_API_KEY=...
# JWT_SECRET=...
